---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import Icon from '../components/icons/Icon.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MarketBoard from '../components/MarketBoard.astro';
import StockList from '../components/StockList.astro';

// 导入市场数据
import marketData from '../../public/data/market_data.json';

const { indices, us_indices, futures, stocks, summary, update_time } = marketData;

// Get all docs and sort by date
const allDocs = await getCollection('docs');

const sortedDocs = allDocs.sort((a, b) => {
  const dateA = a.id.match(/(\d{8})/)?.[1] || '';
  const dateB = b.id.match(/(\d{8})/)?.[1] || '';
  return dateB.localeCompare(dateA);
});

// Format date helper
const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const year = dateStr.slice(0, 4);
  const month = dateStr.slice(4, 6);
  const day = dateStr.slice(6, 8);
  return `${year}年${parseInt(month)}月${parseInt(day)}日`;
};

// Get greeting based on time
const hour = new Date().getHours();
const greetingMap = {
  morning: { text: '早安', icon: 'sun' },
  noon: { text: '午安', icon: 'sun' },
  afternoon: { text: '下午好', icon: 'sun' },
  evening: { text: '晚上好', icon: 'moon' },
};
const greeting = hour < 12 ? greetingMap.morning : hour < 14 ? greetingMap.noon : hour < 18 ? greetingMap.afternoon : greetingMap.evening;

// Today formatted
const today = new Date().toLocaleDateString('zh-CN', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric', 
  weekday: 'long' 
});

// Process articles
const articles = sortedDocs.map((doc, idx) => {
  const dateMatch = doc.id.match(/(\d{8})/);
  const date = dateMatch ? dateMatch[1] : '';
  
  let tag = '其他';
  let tagColor = 'var(--color-bg-elevated)';
  let tagTextColor = 'var(--color-text-muted)';
  
  if (doc.id.includes('财经早餐分析') || doc.id.includes('年报') || doc.id.includes('原文')) {
    tag = '财经早餐';
    tagColor = 'var(--color-accent-dim)';
    tagTextColor = 'var(--color-accent)';
  } else if (doc.id.includes('奏折')) {
    tag = '尚书省奏折';
    tagColor = 'var(--color-danger-dim)';
    tagTextColor = 'var(--color-danger)';
  } else if (doc.id.includes('问题总结')) {
    tag = '工作流文档';
    tagColor = 'var(--color-success-dim)';
    tagTextColor = 'var(--color-success)';
  }
  
  // Extract title from filename
  let title = doc.data.title || '';
  if (!title) {
    const titleMatch = doc.id.match(/-\d{8}-(.+)\.md$/);
    title = titleMatch ? titleMatch[1] : doc.id.replace('.md', '');
    title = title.replace(/-/g, ' ');
  }
  
  return {
    id: doc.id,
    title,
    date,
    formattedDate: formatDate(date),
    tag,
    tagColor,
    tagTextColor,
    index: idx,
  };
});

// Group articles by tag (only show 财经早餐)
const groupedArticles = {
  '财经早餐': articles.filter(a => a.tag === '财经早餐'),
};

// Stats
const stats = [
  { label: '财经早餐', value: groupedArticles['财经早餐'].length },
  { label: '涨停', value: summary?.limit_up_count || 0, suffix: '只' },
  { label: '跌停', value: summary?.limit_down_count || 0, suffix: '只' },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="财经早餐 - 每日财经资讯、宏观新闻、股票分析" />
    <title>财经早餐</title>
    
    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%230a0505' width='100' height='100' rx='20'/><path d='M25 70 L25 45 L40 45 L40 70 M45 70 L45 35 L60 35 L60 70 M65 70 L65 50 L80 50 L80 70' stroke='%23e60000' stroke-width='6' fill='none' stroke-linecap='round'/></svg>">
  </head>
  <body>
    <!-- Background decoration -->
    <div class="bg-decoration" aria-hidden="true">
      <div class="bg-gradient"></div>
      <div class="bg-grid"></div>
      <div class="bg-vignette"></div>
    </div>
    
    <main class="container">
      <!-- Header -->
      <header class="hero">
        <div class="hero-greeting">
          <span class="greeting-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {hour < 18 
                ? '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'
                : '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
              }
            </svg>
          </span>
          <span>{greeting.text}</span>
        </div>
        
        <div class="hero-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none">
            <rect width="48" height="48" rx="12" fill="var(--color-accent-dim)"/>
            <path d="M12 34V24M18 34V20M24 34V26M30 34V18M36 34V22" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        
        <h1 class="hero-title gradient-text">财经早餐</h1>
        
        <p class="hero-subtitle">宏观趋势 · 行业研究 · 投资思考</p>
        
        <time class="hero-date">
          <Icon name="calendar" size={14} />
          <span>{today}</span>
          <span class="hero-date-divider">·</span>
          <span>每日更新</span>
        </time>
        
        <!-- Stats -->
        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat-item">
              <span class="stat-value">{stat.value}{stat.suffix || ''}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </header>

      <!-- Market Data Section -->
      <section class="market-section">
        <MarketBoard indices={indices} usIndices={us_indices} futures={futures} />
        <StockList stocks={stocks} />
        <div class="data-update-time">
          数据更新时间: {update_time}
        </div>
      </section>

      <!-- Sections -->
      <div class="sections">
        {groupedArticles['财经早餐'].length > 0 && (
          <section class="section">
            <SectionHeader title="财经早餐" icon="chart" count={groupedArticles['财经早餐'].length} />
            <div class="article-list">
              {groupedArticles['财经早餐'].map((article) => (
                <ArticleCard {...article} />
              ))}
            </div>
          </section>
        )}


      </div>

      <!-- Footer -->
      <footer class="footer">
        <p>财经早餐 · 由 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> + <a href="https://vercel.com" target="_blank" rel="noopener">Vercel</a> 驱动</p>
      </footer>
    </main>
  </body>
</html>

<style>
  /* Background */
  .bg-decoration {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  
  .bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 70%;
    background: 
      radial-gradient(ellipse 100% 60% at 50% -20%, rgba(230, 0, 0, 0.15), transparent 60%),
      radial-gradient(ellipse 80% 40% at 20% -10%, rgba(200, 0, 0, 0.08), transparent 50%),
      radial-gradient(ellipse 60% 30% at 80% 0%, rgba(230, 0, 0, 0.1), transparent 50%),
      linear-gradient(180deg, rgba(10, 5, 5, 0.95) 0%, transparent 100%);
  }
  
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(230, 0, 0, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(230, 0, 0, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 0%, black 20%, transparent 80%);
  }
  
  .bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 40%, rgba(15, 8, 8, 0.6) 100%);
  }
  
  /* Container */
  .container {
    position: relative;
    z-index: var(--z-base);
  }
  
  /* Hero */
  .hero {
    text-align: center;
    padding-bottom: var(--space-16);
    margin-bottom: var(--space-12);
    position: relative;
  }
  
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
  }
  
  .hero-greeting {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-5);
    animation: fadeInUp 0.5s ease-out;
  }
  
  .greeting-icon {
    display: flex;
  }
  
  .hero-logo {
    margin-bottom: var(--space-5);
    animation: fadeInUp 0.5s ease-out 0.1s both;
  }
  
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 8vw, var(--font-size-4xl));
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
    animation: fadeInUp 0.5s ease-out 0.15s both;
  }
  
  .hero-subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    font-weight: var(--font-weight-light);
    margin-bottom: var(--space-5);
    animation: fadeInUp 0.5s ease-out 0.2s both;
  }
  
  .hero-date {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    animation: fadeInUp 0.5s ease-out 0.25s both;
  }
  
  .hero-date-divider {
    opacity: 0.5;
  }
  
  /* Stats */
  .stats-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-top: var(--space-8);
    animation: fadeInUp 0.5s ease-out 0.3s both;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    line-height: 1;
  }
  
  .stat-label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
    letter-spacing: 0.05em;
  }
  
  /* Sections */
  .sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  
  .section {
    animation: fadeInUp 0.5s ease-out 0.4s both;
  }
  
  .article-list {
    display: flex;
    flex-direction: column;
  }

  /* Market Section */
  .market-section {
    margin-bottom: var(--space-8);
    animation: fadeInUp 0.5s ease-out 0.35s both;
  }

  .data-update-time {
    text-align: center;
    font-size: 11px;
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }
  
  /* Footer */
  .footer {
    text-align: center;
    padding: var(--space-16) 0 var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }
  
  .footer a {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  
  .footer a:hover {
    opacity: 0.8;
  }
  
  /* Responsive */
  @media (max-width: 640px) {
    .hero {
      padding-bottom: var(--space-12);
      margin-bottom: var(--space-10);
    }
    
    .hero-logo svg {
      width: 40px;
      height: 40px;
    }
    
    .stats-grid {
      gap: var(--space-6);
    }
    
    .stat-value {
      font-size: var(--font-size-2xl);
    }
  }
</style>
