---
// StockList.astro - 动态加载个股数据
---

<div class="stock-list" id="stock-list">
  <div class="stock-header">
    <span class="stock-title">热门个股</span>
    <span class="stock-subtitle">市盈率 · 市净率</span>
  </div>
  
  <div class="stock-table" id="stock-table">
    <div class="table-head">
      <span>名称</span>
      <span>现价</span>
      <span>涨跌幅</span>
      <span>换手率</span>
      <span>市盈率</span>
      <span>市净率</span>
    </div>
    
    <!-- 由 JS 动态加载 -->
  </div>
</div>

<script>
  const initStockList = () => {
    const loadStocks = async () => {
      try {
        const response = await fetch('/api/update-market');
        const data = await response.json();
        
        if (data.success) {
          renderStocks(data.stocks || []);
        }
      } catch (error) {
        console.error('加载个股失败:', error);
      }
    };

    const renderStocks = (stocks) => {
      const table = document.getElementById('stock-table');
      if (!table) return;

      // 保留表头
      const header = table.querySelector('.table-head');
      table.innerHTML = '';
      table.appendChild(header);

      stocks.forEach(stock => {
        const row = document.createElement('div');
        row.className = `table-row ${getTrendClass(stock.change)}`;
        row.innerHTML = `
          <span class="stock-name">
            <span class="name-text">${stock.name}</span>
            <span class="stock-code">${stock.code}</span>
          </span>
          <span class="stock-price">${formatPrice(stock.price)}</span>
          <span class="stock-change">
            ${stock.change_pct > 0 ? '+' : ''}${stock.change_pct.toFixed(2)}%
          </span>
          <span class="stock-turnover">${(stock.turnover || 0).toFixed(2)}%</span>
          <span class="stock-pe">${formatPe(stock.pe || 0)}</span>
          <span class="stock-pb">${stock.pb ? stock.pb.toFixed(2) : '--'}</span>
        `;
        table.appendChild(row);
      });
    };

    const getTrendClass = (change) => {
      if (change > 0) return 'trend-up';
      if (change < 0) return 'trend-down';
      return 'trend-flat';
    };

    const formatPrice = (price) => {
      if (price >= 10000) {
        return price.toLocaleString('en-US', { maximumFractionDigits: 0 });
      }
      return price.toLocaleString('en-US', { maximumFractionDigits: 2 });
    };

    const formatPe = (pe) => {
      if (pe === 0 || !pe) return '--';
      return pe.toFixed(1);
    };

    // 初始化
    loadStocks();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStockList);
  } else {
    initStockList();
  }
</script>

<style>
  .stock-list {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .stock-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .stock-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .stock-subtitle {
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .stock-table {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .table-head {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 0.8fr 0.8fr 0.8fr;
    gap: 8px;
    padding: 8px 12px;
    font-size: 11px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .table-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 0.8fr 0.8fr 0.8fr;
    gap: 8px;
    padding: 10px 12px;
    background: var(--color-bg);
    border-radius: 6px;
    font-size: 13px;
    align-items: center;
  }

  .table-row.trend-up {
    border-left: 2px solid var(--color-danger);
  }

  .table-row.trend-down {
    border-left: 2px solid var(--color-success);
  }

  .table-row.trend-flat {
    border-left: 2px solid var(--color-border);
  }

  .stock-name {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .name-text {
    font-weight: 500;
    color: var(--color-text);
  }

  .stock-code {
    font-size: 10px;
    color: var(--color-text-muted);
  }

  .stock-price {
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--color-text);
  }

  .trend-up .stock-change {
    color: var(--color-danger);
  }

  .trend-down .stock-change {
    color: var(--color-success);
  }

  .trend-flat .stock-change {
    color: var(--color-text-muted);
  }

  .stock-turnover,
  .stock-pe,
  .stock-pb {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  @media (max-width: 640px) {
    .table-head {
      display: none;
    }

    .table-row {
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .stock-name {
      grid-column: 1;
      grid-row: 1 / 3;
    }

    .stock-price {
      grid-column: 2;
      grid-row: 1;
    }

    .stock-change {
      grid-column: 3;
      grid-row: 1;
    }

    .stock-turnover,
    .stock-pe,
    .stock-pb {
      display: none;
    }
  }
</style>
