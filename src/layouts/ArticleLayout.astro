---
interface Props {
  title: string;
  date?: string;
  tag?: string;
}

const { title, date, tag } = Astro.props;

// 格式化日期
const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  // 假设日期格式为 YYYYMMDD
  if (/^\d{8}$/.test(dateStr)) {
    const year = dateStr.slice(0, 4);
    const month = dateStr.slice(4, 6);
    const day = dateStr.slice(6, 8);
    return `${year}年${parseInt(month)}月${parseInt(day)}日`;
  }
  return dateStr;
};
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - 财经早餐</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      :root {
        --bg-primary: #0a0a0a;
        --bg-card: #141414;
        --bg-hover: #1a1a1a;
        --text-primary: #fafafa;
        --text-secondary: #a1a1a1;
        --text-muted: #6b6b6b;
        --accent: #d4a853;
        --accent-dim: #8a7235;
        --border: #262626;
        --gradient-accent: linear-gradient(135deg, #d4a853 0%, #e8c87a 50%, #d4a853 100%);
      }
      
      body {
        font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.8;
        min-height: 100vh;
      }
      
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
          radial-gradient(ellipse 80% 50% at 50% -20%, rgba(212, 168, 83, 0.08), transparent),
          radial-gradient(ellipse 60% 40% at 100% 0%, rgba(212, 168, 83, 0.05), transparent);
        pointer-events: none;
        z-index: 0;
      }
      
      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 60px 24px;
        position: relative;
        z-index: 1;
      }
      
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent);
        text-decoration: none;
        font-size: 14px;
        margin-bottom: 32px;
        transition: opacity 0.2s;
      }
      
      .back-link:hover {
        opacity: 0.8;
      }
      
      article {
        animation: fadeInUp 0.6s ease-out;
      }
      
      .article-header {
        margin-bottom: 48px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
      }
      
      .article-meta {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
      }
      
      .tag {
        display: inline-block;
        padding: 4px 12px;
        background: rgba(212, 168, 83, 0.15);
        color: var(--accent);
        font-size: 12px;
        border-radius: 4px;
      }
      
      .article-date {
        color: var(--text-muted);
        font-size: 14px;
      }
      
      h1 {
        font-family: 'Noto Serif SC', serif;
        font-size: 32px;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 16px;
        background: var(--gradient-accent);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      .article-content {
        font-size: 16px;
      }
      
      .article-content :global(h2) {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 48px 0 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
      }
      
      .article-content :global(h3) {
        font-size: 17px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 32px 0 16px;
      }
      
      .article-content :global(p) {
        margin-bottom: 16px;
        color: var(--text-secondary);
      }
      
      .article-content :global(ul), .article-content :global(ol) {
        margin-bottom: 16px;
        padding-left: 24px;
        color: var(--text-secondary);
      }
      
      .article-content :global(li) {
        margin-bottom: 8px;
      }
      
      .article-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-size: 14px;
      }
      
      .article-content :global(th), .article-content :global(td) {
        padding: 12px 16px;
        border: 1px solid var(--border);
        text-align: left;
      }
      
      .article-content :global(th) {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text-primary);
      }
      
      .article-content :global(td) {
        color: var(--text-secondary);
      }
      
      .article-content :global(tr:hover) :global(td) {
        background: var(--bg-hover);
      }
      
      .article-content :global(blockquote) {
        margin: 24px 0;
        padding: 20px 24px;
        background: var(--bg-card);
        border-left: 3px solid var(--accent);
        border-radius: 0 8px 8px 0;
        color: var(--text-secondary);
        font-style: italic;
      }
      
      .article-content :global(strong) {
        color: var(--text-primary);
        font-weight: 600;
      }
      
      .article-content :global(code) {
        background: var(--bg-card);
        padding: 2px 6px;
        border-radius: 4px;
        font-family: 'Fira Code', monospace;
        font-size: 14px;
        color: var(--accent);
      }
      
      .article-content :global(pre) {
        background: var(--bg-card);
        padding: 20px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 24px 0;
      }
      
      .article-content :global(pre code) {
        background: none;
        padding: 0;
      }
      
      .article-content :global(hr) {
        border: none;
        height: 1px;
        background: var(--border);
        margin: 48px 0;
      }
      
      footer {
        text-align: center;
        padding: 64px 0 32px;
        color: var(--text-muted);
        font-size: 12px;
      }
      
      footer a {
        color: var(--accent);
        text-decoration: none;
      }
      
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      @media (max-width: 640px) {
        .container {
          padding: 40px 16px;
        }
        h1 {
          font-size: 24px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <a href="/" class="back-link">← 返回首页</a>
      
      <article>
        <header class="article-header">
          <div class="article-meta">
            {tag && <span class="tag">{tag}</span>}
            {date && <span class="article-date">{formatDate(date)}</span>}
          </div>
          <h1>{title}</h1>
        </header>
        
        <div class="article-content">
          <slot />
        </div>
      </article>
      
      <footer>
        <p>财经早餐 · 由 <a href="https://astro.build" target="_blank">Astro</a> + <a href="https://vercel.com" target="_blank">Vercel</a> 驱动</p>
      </footer>
    </div>
  </body>
</html>
